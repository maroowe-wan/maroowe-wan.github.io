# === 블랙리스트 방식 .gitignore ===
# 기본적으로 모든 파일을 버전관리한다(소스·콘텐츠·지침 포함).
# 비밀값(.env)과 개인 설정(settings.local.json), 임시·캐시 산출물만 제외한다.

# 개인 설정 — 권한 모드 등 사용자별 로컬 설정
/.claude/settings.local.json

# 비밀값 — API 키 등 (공개 저장소이므로 절대 추적 금지)
.env
*.env
!/.env.example
secrets.json

# 임시·디버그 산출물 (에이전트가 실수로 만든 탐색용 파일 등)
_tmp*
*.tmp
*.bak
*.swp
temp/

# 파이썬 캐시
__pycache__/
*.py[cod]
*.egg-info/

# OS 산출물
.DS_Store
Thumbs.db
desktop.ini
